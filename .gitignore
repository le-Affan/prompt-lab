# ============================================================
# Python / API
# ============================================================

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
.eggs/

# Unit test and coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# MyPy
.mypy_cache/
.dmypy.json

# Ruff / linters
.ruff_cache/

# ============================================================
# Environment & Secrets  (NEVER commit these)
# ============================================================
.env
.env.*
!.env.example
!.env.*.example
!.env.local.example

# ============================================================
# Next.js / Web
# ============================================================
apps/web/.next/
apps/web/out/
apps/web/node_modules/
apps/web/.turbo/

# ============================================================
# Node (general)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ============================================================
# Docker
# ============================================================
# Keep docker-compose.yml tracked; ignore local overrides
docker-compose.override.yml

# ============================================================
# Databases (local dev)
# ============================================================
*.db
*.sqlite
*.sqlite3

# ============================================================
# OS-generated files
# ============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encdata
desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================================
# IDEs & editors
# ============================================================

# VS Code – keep shared settings, ignore personal/workspace overrides
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains
.idea/

# Vim / Emacs swaps
*.swp
*.swo
*~

# ============================================================
# Misc
# ============================================================
*.log
*.tmp
*.bak
